---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from './HeroSection.astro';
import Container from './Container.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import ServiceCard from './ServiceCard.astro';
import AreaCard from './AreaCard.astro';
import FAQSection from './FAQSection.astro';
import CTASection from './CTASection.astro';
import SplitImageSection from './SplitImageSection.astro';
import { getNearbyAreas, type PriorityArea } from '../data/areas';
import { SITE } from '../data/site';

interface Props {
  area: PriorityArea;
}

const { area } = Astro.props;
const nearbyAreas = getNearbyAreas(area);
const localServiceSchema = {
  "@type": "Service",
  name: `Luftvärmepump i ${area.name}`,
  serviceType: "Installation, service och felsökning av luftvärmepump",
  description: area.description,
  provider: {
    "@id": `${SITE.url}/#business`,
  },
  areaServed: {
    "@type": "City",
    name: area.name,
  },
  url: new URL(area.url, SITE.url).toString(),
};

const services = [
  {
    title: "Kostnadsfritt hembesök",
    description: `Vi går igenom huset i ${area.name} och tar fram en lösning som passar bostadens behov.`,
    link: "/offert",
    image: "/images/hero.png",
    imageAlt: `Hembesök inför luftvärmepump i ${area.name}`,
  },
  {
    title: "Installation",
    description: `Fackmässig installation av luftvärmepump i ${area.name} med tydlig offert och ROT-avdrag.`,
    link: "/installation-luftvarmepump",
    image: "/images/service-installation.png",
    imageAlt: `Installation av luftvärmepump i ${area.name}`,
  },
  {
    title: "Service",
    description: `Regelbunden service hjälper pumpen att behålla god effekt och längre livslängd.`,
    link: "/service-luftvarmepump",
    image: "/images/service-maintenance.png",
    imageAlt: `Service av luftvärmepump i ${area.name}`,
  },
  {
    title: "Felsökning",
    description: `Vi felsöker vid felkoder, missljud, dålig värme eller andra problem med pumpen.`,
    link: "/felsokning-luftvarmepump",
    image: "/images/service-troubleshooting.png",
    imageAlt: `Felsökning av luftvärmepump i ${area.name}`,
  },
];
---

<BaseLayout title={area.title} description={area.description} image="/images/hero.png" structuredData={localServiceSchema}>
  <Breadcrumbs crumbs={[{ text: "Områden" }, { text: area.name }]} />

  <HeroSection
    eyebrow={`Lokal landningssida för ${area.name}`}
    title={area.heroTitle}
    description={area.heroText}
    primaryCTA={{ text: `Begär offert i ${area.name}`, link: "/offert" }}
    secondaryCTA={{ text: "Se produkter", link: "/produkter" }}
    image="/images/hero.png"
    imageAlt={`Luftvärmepump installerad i ${area.name}`}
    size="medium"
  />

  <section class="section-padding">
    <Container>
      <div class="intro-layout">
        <div>
          <span class="eyebrow">Luftvärmepump {area.name}</span>
          <h2>Rätt pump, rätt placering och tydlig offert</h2>
          <p>{area.intro}</p>
        </div>
        <div class="local-note">
          <h3>Lokalt fokus</h3>
          <p>{area.localAngle}</p>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-padding bg-light">
    <Container>
      <div class="section-header">
        <span class="eyebrow">Tjänster</span>
        <h2>Det här hjälper vi dig med i {area.name}</h2>
      </div>
      <div class="services-grid">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </Container>
  </section>

  <section class="section-padding">
    <Container>
      <div class="benefits-grid">
        <div class="benefit-item">
          <h3>{area.benefitOne}</h3>
          <p>{area.benefitOneText}</p>
        </div>
        <div class="benefit-item">
          <h3>{area.benefitTwo}</h3>
          <p>{area.benefitTwoText}</p>
        </div>
        <div class="benefit-item">
          <h3>{area.benefitThree}</h3>
          <p>{area.benefitThreeText}</p>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-padding bg-light">
    <Container>
      <div class="local-content-layout">
        <div class="local-copy">
          <span class="eyebrow">Lokalt</span>
          <h2>{area.localConditionsTitle}</h2>
          {area.localConditions.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <aside class="place-panel">
          <h3>{area.neighborhoodsTitle}</h3>
          <div class="place-list" aria-label={`Områden för luftvärmepump i ${area.name}`}>
            {area.neighborhoods.map((place) => <span>{place}</span>)}
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <section class="section-padding">
    <Container>
      <div class="section-header">
        <span class="eyebrow">Rådgivning</span>
        <h2>{area.fitTitle}</h2>
      </div>
      <div class="detail-grid">
        {area.fitItems.map((item) => (
          <article class="detail-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <SplitImageSection
    title={`Prisförslag för luftvärmepump i ${area.name}`}
    description="Vi hjälper dig att jämföra rätt modell, installationsförutsättningar och ROT-avdrag innan du bestämmer dig."
    buttonText="Begär offert"
    buttonLink="/offert"
    image="/images/service-installation.png"
    imageAlt={`Prisförslag för luftvärmepump i ${area.name}`}
  />

  <section class="section-padding">
    <Container>
      <div class="section-header">
        <span class="eyebrow">Behov</span>
        <h2>{area.situationTitle}</h2>
      </div>
      <div class="situation-list">
        {area.situations.map((situation) => (
          <article class="situation-item">
            <h3>{situation.title}</h3>
            <p>{situation.text}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-padding bg-light">
    <Container>
      <div class="section-header compact">
        <span class="eyebrow">Prioriterade områden</span>
        <h2>Vi fokuserar på tre områden</h2>
      </div>
      <div class="areas-grid">
        {nearbyAreas.map((nearby) => (
          <AreaCard
            name={nearby.name}
            link={nearby.url}
            description={`Luftvärmepump i ${nearby.name}`}
          />
        ))}
      </div>
    </Container>
  </section>

  <FAQSection faqs={area.faqs} />

  <CTASection
    title={`Vill du ha hjälp i ${area.name}?`}
    description="Skicka en offertförfrågan så återkommer vi med rådgivning, prisbild och nästa steg."
    buttonText={`Få offert i ${area.name}`}
    buttonLink="/offert"
  />
</BaseLayout>

<style>
  .bg-light {
    background: var(--bg-subtle);
  }

  .intro-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    gap: 3rem;
    align-items: start;
  }

  .intro-layout h2,
  .section-header h2 {
    text-transform: none;
    letter-spacing: 0;
  }

  .intro-layout p,
  .local-note p,
  .local-copy p,
  .place-panel p,
  .detail-card p,
  .situation-item p {
    color: var(--text-muted);
    line-height: 1.75;
  }

  .local-note,
  .benefit-item,
  .place-panel,
  .detail-card,
  .situation-item {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 2rem;
  }

  .local-note h3,
  .benefit-item h3,
  .place-panel h3,
  .detail-card h3,
  .situation-item h3 {
    font-size: 1.15rem;
    margin-bottom: 0.75rem;
  }

  .local-content-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 3rem;
    align-items: start;
  }

  .local-copy {
    max-width: 760px;
  }

  .local-copy h2 {
    text-transform: none;
    letter-spacing: 0;
  }

  .local-copy p + p {
    margin-top: 1rem;
  }

  .place-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .place-list span {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--border-warm);
    border-radius: 999px;
    background: var(--secondary-soft);
    color: var(--secondary);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .section-header {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }

  .section-header.compact {
    margin-bottom: 2rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 2rem;
  }

  .benefits-grid,
  .detail-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .situation-list {
    display: grid;
    gap: 1rem;
  }

  .situation-item {
    display: grid;
    grid-template-columns: minmax(180px, 0.35fr) minmax(0, 0.65fr);
    gap: 1.5rem;
    align-items: start;
  }

  .areas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    gap: 1rem;
  }

  @media (max-width: 820px) {
    .intro-layout,
    .local-content-layout,
    .benefits-grid,
    .detail-grid,
    .situation-item {
      grid-template-columns: 1fr;
    }
  }
</style>
