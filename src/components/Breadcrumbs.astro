---
import Container from './Container.astro';
import { SITE } from '../data/site';

interface Crumb {
  text: string;
  link?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
const allCrumbs = [{ text: "Start", link: "/" }, ...crumbs];
const currentPath = Astro.url.pathname;
const absoluteUrl = (path: string) => new URL(path, SITE.url).toString();
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: allCrumbs.map((crumb, index) => {
    const path = crumb.link ?? (index === allCrumbs.length - 1 ? currentPath : "");
    return {
      "@type": "ListItem",
      position: index + 1,
      name: crumb.text,
      ...(path ? { item: absoluteUrl(path) } : {}),
    };
  }),
};
---

<div class="breadcrumbs-wrapper">
  <Container>
    <nav aria-label="Breadcrumb" class="breadcrumbs">
      <ol>
        <li><a href="/">Start</a></li>
        {crumbs.map((crumb, index) => {
          const isCurrent = index === crumbs.length - 1;

          return (
          <li>
            <span class="separator">/</span>
            {crumb.link ? (
              <a href={crumb.link} aria-current={isCurrent ? "page" : undefined}>{crumb.text}</a>
            ) : isCurrent ? (
              <span aria-current="page">{crumb.text}</span>
            ) : (
              <span>{crumb.text}</span>
            )}
          </li>
          );
        })}
      </ol>
    </nav>
  </Container>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</div>

<style>
  .breadcrumbs-wrapper {
    padding: 1rem 0;
    background: var(--white);
    border-bottom: 1px solid var(--border);
  }
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .breadcrumbs li {
    display: flex;
    align-items: center;
  }
  .separator {
    margin: 0 0.75rem;
    color: var(--border);
  }
  .breadcrumbs a:hover {
    color: var(--secondary-hover);
    text-decoration: underline;
  }
  [aria-current="page"] {
    color: var(--text-main);
    font-weight: 500;
  }
</style>
