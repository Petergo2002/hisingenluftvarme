---
import Container from './Container.astro';
import { SITE } from '../data/site';
---

<header class="header">
  <Container>
    <div class="header-inner">
      <a href="/" class="logo" aria-label={`${SITE.name} startsida`}>
        <img src="/hisingen_luftv%C3%A4rme_logo%20-%20Sebastian%20Fihn.png" alt={SITE.name} />
      </a>

      <nav class="desktop-nav" aria-label="Huvudnavigation">
        <ul class="nav-links">
          <li><a href="/">Start</a></li>
          <li><a href="/produkter">Produkter</a></li>
          <li><a href="/projekt">Projekt</a></li>
          <li><a href="/#tjanster">Tjänster</a></li>
          <li><a href="/offert">Kontakt</a></li>
        </ul>
      </nav>

      <div class="desktop-actions">
        <a href={SITE.phoneHref} class="nav-link-simple">{SITE.phoneDisplay}</a>
        <a href="/offert" class="btn btn-primary">Begär offert</a>
      </div>

      <details class="mobile-nav">
        <summary class="menu-toggle" aria-label="Öppna meny">
          <svg class="icon-menu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </summary>

        <div class="mobile-menu">
          <a href={SITE.phoneHref} class="mobile-phone">{SITE.phoneDisplay}</a>

          <ul class="mobile-nav-links">
            <li><a href="/">Start</a></li>
            <li><a href="/produkter">Produkter</a></li>
            <li><a href="/projekt">Projekt</a></li>
            <li><a href="/#tjanster">Tjänster</a></li>
            <li><a href="/offert">Kontakt</a></li>
          </ul>

          <a href="/offert" class="btn btn-primary mobile-cta">Begär offert</a>
        </div>
      </details>
    </div>
  </Container>
</header>

<style>
  .header {
    background: rgba(255, 255, 255, 0.94);
    border-bottom: 1px solid var(--border-warm);
    box-shadow: 0 10px 30px rgba(20, 20, 20, 0.06);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 1rem 0;
  }

  .header-inner {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .logo img {
    display: block;
    width: auto;
    height: 62px;
    object-fit: contain;
  }

  .desktop-nav {
    justify-self: center;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a,
  .mobile-nav-links a {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--secondary);
    transition: color 0.2s ease;
  }

  .nav-links a:hover,
  .mobile-nav-links a:hover {
    color: var(--secondary-hover);
  }

  .desktop-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-link-simple {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--secondary);
    white-space: nowrap;
  }

  .nav-link-simple:hover {
    color: var(--secondary-hover);
  }

  .desktop-actions :global(.btn-primary),
  .mobile-cta {
    background: var(--secondary);
    border-color: var(--secondary);
    color: var(--white);
  }

  .desktop-actions :global(.btn-primary:hover),
  .mobile-cta:hover {
    background: var(--secondary-hover);
    border-color: var(--secondary-hover);
    color: var(--white);
  }

  .mobile-nav {
    display: none;
  }

  .menu-toggle {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--border-warm);
    border-radius: 6px;
    color: var(--secondary);
    cursor: pointer;
    background: var(--secondary-soft);
  }

  .menu-toggle::-webkit-details-marker {
    display: none;
  }

  .menu-toggle svg {
    width: 22px;
    height: 22px;
  }

  .icon-close {
    display: none;
  }

  .mobile-nav[open] .icon-menu {
    display: none;
  }

  .mobile-nav[open] .icon-close {
    display: block;
  }

  .mobile-menu {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    width: min(20rem, calc(100vw - 3rem));
    padding: 1rem;
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid var(--border-warm);
    border-radius: 8px;
    box-shadow: 0 24px 60px rgba(20, 20, 20, 0.16);
  }

  .mobile-phone {
    display: block;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-warm);
    color: var(--secondary);
    font-weight: 700;
  }

  .mobile-nav-links {
    display: grid;
    gap: 1rem;
  }

  .mobile-cta {
    width: 100%;
    margin-top: 1.25rem;
  }

  @media (max-width: 900px) {
    .header-inner {
      grid-template-columns: auto 1fr auto;
    }

    .desktop-nav,
    .desktop-actions {
      display: none;
    }

    .mobile-nav {
      display: block;
      justify-self: end;
    }
  }

  @media (max-width: 640px) {
    .header {
      padding: 0.75rem 0;
    }

    .logo img {
      height: 50px;
    }
  }
</style>
