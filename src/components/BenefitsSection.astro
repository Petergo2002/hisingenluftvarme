---
import Container from './Container.astro';

interface Benefit {
  title: string;
  description: string;
  icon?: string;
  link?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  benefits: Benefit[];
}

const { eyebrow, title, benefits } = Astro.props;
---

<section class="benefits section-padding">
  <Container>
    <div class="section-header">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2>{title}</h2>
    </div>
    <div class="benefits-grid">
      {benefits.map(benefit => (
        benefit.link ? (
          <a class="benefit-card" href={benefit.link} aria-label={`Läs mer om ${benefit.title}`}>
            {benefit.icon ? (
              <div class="icon-wrapper" set:html={benefit.icon} />
            ) : (
              <div class="icon-placeholder"></div>
            )}
            <h3>{benefit.title}</h3>
            <p>{benefit.description}</p>
          </a>
        ) : (
          <div class="benefit-card">
            {benefit.icon ? (
              <div class="icon-wrapper" set:html={benefit.icon} />
            ) : (
              <div class="icon-placeholder"></div>
            )}
            <h3>{benefit.title}</h3>
            <p>{benefit.description}</p>
          </div>
        )
      ))}
    </div>
  </Container>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
    gap: 1.5rem;
  }
  
  @media (max-width: 640px) {
    .benefits-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
  .benefit-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    padding: 2rem;
    text-align: left;
    display: block;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .benefit-card:hover {
    border-color: var(--border-warm);
    box-shadow: 0 24px 60px rgba(247, 146, 46, 0.1);
    transform: translateY(-2px);
  }
  .benefit-card:focus-visible {
    outline: 3px solid rgba(247, 146, 46, 0.35);
    outline-offset: 4px;
  }
  .icon-wrapper {
    width: 48px;
    height: 48px;
    margin: 0 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--secondary);
  }
  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }
  .icon-placeholder {
    width: 48px;
    height: 48px;
    background: transparent;
    border: 1px solid var(--border-warm);
    margin: 0 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  h3 {
    margin-bottom: 1rem;
    font-size: 1.125rem;
    font-weight: 800;
  }
  p {
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
</style>
