---
import { SITE } from "../data/site";

const redirectUrl = "/offert";
const canonicalUrl = new URL(redirectUrl, SITE.url).toString();
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${redirectUrl}`} />
    <link rel="canonical" href={canonicalUrl} />
    <title>Kontakt | {SITE.name}</title>
  </head>
  <body>
    <p>Du skickas vidare till <a href={redirectUrl}>kontakt och offert</a>.</p>
    <script define:vars={{ redirectUrl }}>window.location.replace(redirectUrl);</script>
  </body>
</html>
