---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';
import { PRODUCTS, SITE } from '../data/site';

const title = "Produkter";
const description = "Luftvärmepumpar från Hisingen Luftvärme med pris efter ROT-avdrag och inklusive standardinstallation.";
const productListSchema = {
  "@type": "ItemList",
  name: "Luftvärmepumpar med installation",
  itemListElement: PRODUCTS.map((product, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Product",
      name: product.name,
      description: product.specs.join(", "),
      category: "Luftvärmepump",
      brand: {
        "@type": "Brand",
        name: product.name.split(" ")[0],
      },
      offers: {
        "@type": "Offer",
        price: product.price.replace(/\D/g, ""),
        priceCurrency: "SEK",
        availability: "https://schema.org/InStock",
        url: new URL("/produkter", SITE.url).toString(),
        seller: {
          "@id": `${SITE.url}/#business`,
        },
      },
    },
  })),
};
---

<BaseLayout title={title} description={description} image="/images/service-installation.jpg" structuredData={productListSchema}>
  <Breadcrumbs crumbs={[{ text: title }]} />

  <section class="section-padding bg-light">
    <Container>
      <div class="section-header text-center">
        <span class="eyebrow">Produkter</span>
        <h1>Luftvärmepumpar med installation</h1>
        <p class="text-muted">Alla priser visas efter ROT-avdrag och inklusive standardinstallation.</p>
      </div>

      <div class="products-grid">
        {PRODUCTS.map((product) => (
          <article class="surface product-card">
            {product.image && (
              <img
                src={product.image}
                alt={product.imageAlt ?? product.name}
                class="product-image"
                loading="lazy"
                decoding="async"
              />
            )}
            <div>
              <h2>{product.name}</h2>
              <p class="price">{product.price}</p>
              <p class="price-note">Pris efter ROT-avdrag, inklusive standardinstallation.</p>
            </div>
            <ul>
              {product.specs.map((spec) => <li>{spec}</li>)}
            </ul>
            {product.productSheet && (
              <a href={product.productSheet} class="product-sheet" target="_blank" rel="noopener noreferrer">
                Produktblad
              </a>
            )}
          </article>
        ))}
      </div>
    </Container>
  </section>

  <CTASection
    title="Osäker på vilken modell som passar?"
    description="Vi gör kostnadsfria hembesök i Göteborg, Stenungsund och Lilla Edet och hjälper dig att hitta den bästa lösningen för ditt hus."
    buttonText="Boka hembesök"
    buttonLink="/offert"
  />
</BaseLayout>

<style>
  .bg-light {
    background: var(--bg-subtle);
  }
  .section-header {
    margin-bottom: 4rem;
  }
  .text-center {
    text-align: center;
  }
  .section-header h1,
  .section-header p,
  .product-card h2,
  .product-card li,
  .price-note {
    overflow-wrap: anywhere;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }
  .product-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0;
  }
  .product-card > div,
  .product-card > ul,
  .product-sheet {
    margin-left: 2rem;
    margin-right: 2rem;
  }
  .product-card > div:first-child {
    margin-top: 2rem;
  }
  .product-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: var(--bg-subtle);
  }
  .product-card h2 {
    font-size: 1.35rem;
    margin-bottom: 1rem;
  }
  .price {
    color: var(--secondary-hover);
    font-size: 1.6rem;
    font-weight: 900;
    margin-bottom: 0.25rem;
  }
  .price-note {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .product-card ul {
    list-style: disc;
    padding-left: 1.2rem;
  }
  .product-card li {
    color: var(--text-muted);
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }
  .product-sheet {
    margin-top: auto;
    margin-bottom: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    color: var(--secondary-hover);
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .product-sheet:hover {
    color: var(--secondary);
  }

  @media (max-width: 640px) {
    .section-header {
      margin-bottom: 2.5rem;
    }

    .section-header h1 {
      font-size: clamp(2rem, 10vw, 2.75rem);
    }

    .products-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .product-card {
      gap: 1.25rem;
    }
    .product-card > div,
    .product-card > ul,
    .product-sheet {
      margin-left: 1.5rem;
      margin-right: 1.5rem;
    }
    .product-card > div:first-child {
      margin-top: 1.5rem;
    }

    .product-card h2 {
      font-size: 1.2rem;
      margin-bottom: 0.75rem;
    }

    .price {
      font-size: 1.45rem;
    }
    .product-sheet {
      margin-bottom: 1.5rem;
    }
  }
</style>
